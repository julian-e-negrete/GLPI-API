# GLPI API Proxy - Configuration Template
# Copiar este archivo a .env y completar con los valores reales

# URL del servidor GLPI
GLPI_API_URL=http://192.168.1.33:80

# Credenciales OAuth (obtener de la configuración de la API de GLPI)
GLPI_CLIENT_ID=ad656bf992e92a427b4dfd75063bbaf63813049c59ac69f8e874c45d088caa18
GLPI_CLIENT_SECRET=415ade7681bc086a64dfb36ec0f81b1e6126e211ca4072c3e9f2c7df603d81bc

# Credenciales de usuario GLPI
GLPI_USERNAME=admin
GLPI_PASSWORD=your_password_here

# Configuración del Proxy
PROXY_HOST=0.0.0.0
PROXY_PORT=8080

# Configuración de Logging
LOG_LEVEL=INFO
LOG_DIR=./logs

# Timeout para requests HTTP (segundos)
HTTP_TIMEOUT=30